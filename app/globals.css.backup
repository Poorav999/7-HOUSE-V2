@import "tailwindcss";

@theme {
  --font-syncopate: var(--font-syncopate);
  --font-space: var(--font-space);
}

/* ═══════════════════════════════════════════════════
   ROOT TOKENS
   ═══════════════════════════════════════════════════ */
:root {
  background: #08080a;
  color: #d4d4d4;
  --bg-primary: #08080a;
  --bg-surface: #0e0e12;
  --bg-elevated: #141419;
  --border-subtle: rgba(255, 255, 255, 0.06);
  --border-medium: rgba(255, 255, 255, 0.10);
  --accent: #a3e048;
  --accent-dim: #5a8c3a;
  --text-primary: #e8e8e8;
  --text-secondary: rgba(255, 255, 255, 0.50);
  --text-muted: rgba(255, 255, 255, 0.25);
  --glow-accent: rgba(163, 224, 72, 0.15);
}

html {
  scroll-behavior: auto !important;
}

body {
  background: var(--bg-primary);
  min-height: 100vh;
  overflow-x: hidden;
  cursor: auto !important;
}

* {
  cursor: auto !important;
}
a, button, [role="button"] {
  cursor: pointer !important;
}

/* ═══════════════════════════════════════════════════
   FLOATING NAVBAR
   ═══════════════════════════════════════════════════ */
.navbar-float {
  background: rgba(10, 10, 14, 0.75);
  backdrop-filter: blur(24px) saturate(1.3);
  -webkit-backdrop-filter: blur(24px) saturate(1.3);
  border: 1px solid var(--border-subtle);
  border-radius: 14px;
  box-shadow:
    0 4px 24px rgba(0, 0, 0, 0.5),
    0 0 0 0.5px rgba(255, 255, 255, 0.04) inset,
    0 1px 0 rgba(255, 255, 255, 0.03) inset;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}
.navbar-float:hover {
  border-color: var(--border-medium);
  box-shadow:
    0 8px 40px rgba(0, 0, 0, 0.6),
    0 0 0 0.5px rgba(255, 255, 255, 0.06) inset,
    0 1px 0 rgba(255, 255, 255, 0.04) inset;
}

/* ═══════════════════════════════════════════════════
   USER PROFILE BADGE
   ═══════════════════════════════════════════════════ */
.user-profile-badge {
  background: rgba(10, 10, 14, 0.6);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid var(--border-subtle);
  border-radius: 10px;
  padding: 6px 12px;
  transition: all 0.3s ease;
}
.user-profile-badge:hover {
  border-color: var(--border-medium);
  background: rgba(10, 10, 14, 0.8);
}

/* ═══════════════════════════════════════════════════
   GAME CARD — Retro Console Style
   ═══════════════════════════════════════════════════ */
.game-card {
  display: flex;
  flex-direction: column;
  width: 260px;
  min-width: 260px;
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: 12px;
  overflow: hidden;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
}
.game-card::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 12px;
  padding: 1px;
  background: linear-gradient(
    160deg,
    rgba(163, 224, 72, 0) 0%,
    rgba(163, 224, 72, 0) 40%,
    rgba(163, 224, 72, 0.08) 100%
  );
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
  transition: opacity 0.4s ease;
  opacity: 0;
}
.game-card:hover {
  transform: translateY(-6px);
  border-color: rgba(163, 224, 72, 0.15);
  box-shadow:
    0 16px 48px rgba(0, 0, 0, 0.5),
    0 0 40px var(--glow-accent);
}
.game-card:hover::before {
  opacity: 1;
}

/* Card Top Bar */
.game-card-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 14px;
  border-bottom: 1px solid var(--border-subtle);
  background: rgba(255, 255, 255, 0.015);
}

/* Card Image Display */
.game-card-display {
  position: relative;
  width: 100%;
  aspect-ratio: 4 / 5;
  background: var(--bg-primary);
  overflow: hidden;
}

/* Screen area */
.game-card-screen {
  position: relative;
  width: 100%;
  aspect-ratio: 4 / 5; /* matches display area */
  background: var(--bg-primary);
  overflow: hidden;
  border-top: 1px solid var(--border-subtle);
  border-bottom: 1px solid var(--border-subtle);
}

/* Subtle screen glow */
.screen-glow {
  position: absolute;
  inset: 0;
  background: radial-gradient(circle, rgba(163,224,72,0.12), transparent 70%);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

/* Knob button (styled like console button but slimmer) */
.knob-btn {
  width: 24px;
  height: 24px;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255,255,255,0.35);
  background: rgba(255,255,255,0.04);
  border: 1px solid var(--border-subtle);
  transition: all 0.25s ease;
}
.knob-btn:hover {
  color: var(--accent);
  background: rgba(163,224,72,0.08);
  border-color: rgba(163,224,72,0.2);
  box-shadow: 0 0 12px rgba(163,224,72,0.1);
}

/* Hover lift and screen glow increase */
.game-card:hover {
  transform: translateY(-8px) scale(1.02);
}
.game-card:hover .screen-glow {
  opacity: 0.25;
}

/* Console Button */
.console-btn {
  width: 28px;
  height: 28px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255, 255, 255, 0.35);
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid var(--border-subtle);
  transition: all 0.25s ease;
}
.console-btn:hover {
  color: var(--accent);
  background: rgba(163, 224, 72, 0.08);
  border-color: rgba(163, 224, 72, 0.2);
  box-shadow: 0 0 12px rgba(163, 224, 72, 0.1);
}

/* ═══════════════════════════════════════════════════
   VIDEO STRIP
   ═══════════════════════════════════════════════════ */
.video-strip {
  position: relative;
  width: 100%;
  height: 80px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-surface);
  border-top: 1px solid var(--border-subtle);
  border-bottom: 1px solid var(--border-subtle);
  overflow: hidden;
}

/* ═══════════════════════════════════════════════════
   ANIMATED MINECRAFT BACKGROUND
   ═══════════════════════════════════════════════════ */
.mc-bg-canvas {
  position: fixed;
  inset: 0;
  z-index: -1;
  pointer-events: none;
  overflow: hidden;
}

/* Floating grid particles */
.mc-bg-canvas::before {
  content: '';
  position: absolute;
  inset: -20%;
  background-image:
    radial-gradient(1px 1px at 10% 20%, rgba(163, 224, 72, 0.12) 0%, transparent 100%),
    radial-gradient(1px 1px at 30% 60%, rgba(163, 224, 72, 0.08) 0%, transparent 100%),
    radial-gradient(1px 1px at 50% 30%, rgba(90, 140, 58, 0.10) 0%, transparent 100%),
    radial-gradient(1px 1px at 70% 80%, rgba(163, 224, 72, 0.06) 0%, transparent 100%),
    radial-gradient(1px 1px at 90% 40%, rgba(90, 140, 58, 0.08) 0%, transparent 100%),
    radial-gradient(1.5px 1.5px at 20% 90%, rgba(163, 224, 72, 0.10) 0%, transparent 100%),
    radial-gradient(1px 1px at 80% 10%, rgba(90, 140, 58, 0.06) 0%, transparent 100%);
  animation: mc-drift 30s linear infinite;
}

/* Subtle voxel grid overlay */
.mc-bg-canvas::after {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.012) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255, 255, 255, 0.012) 1px, transparent 1px);
  background-size: 60px 60px;
  animation: mc-grid-drift 45s linear infinite;
}

@keyframes mc-drift {
  0%   { transform: translate(0, 0); }
  100% { transform: translate(40px, -60px); }
}

@keyframes mc-grid-drift {
  0%   { transform: translate(0, 0); }
  100% { transform: translate(60px, 60px); }
}

/* Ambient glow orbs */
.mc-glow-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.15;
  animation: orb-pulse 8s ease-in-out infinite alternate;
}
.mc-glow-orb:nth-child(1) {
  width: 400px;
  height: 400px;
  background: radial-gradient(circle, var(--accent-dim), transparent 70%);
  top: 10%;
  left: -5%;
  animation-delay: 0s;
  animation-duration: 10s;
}
.mc-glow-orb:nth-child(2) {
  width: 300px;
  height: 300px;
  background: radial-gradient(circle, #2a4a6a, transparent 70%);
  bottom: 20%;
  right: -3%;
  animation-delay: -3s;
  animation-duration: 12s;
}
.mc-glow-orb:nth-child(3) {
  width: 250px;
  height: 250px;
  background: radial-gradient(circle, var(--accent-dim), transparent 70%);
  top: 50%;
  left: 40%;
  animation-delay: -6s;
  animation-duration: 14s;
  opacity: 0.08;
}

@keyframes orb-pulse {
  0%   { opacity: 0.06; transform: scale(1); }
  100% { opacity: 0.18; transform: scale(1.15); }
}

/* ═══════════════════════════════════════════════════
   VIDEO PROGRESS ANIMATION
   ═══════════════════════════════════════════════════ */
@keyframes video-progress {
  0%   { width: 0%; }
  100% { width: 100%; }
}
.animate-video-progress {
  animation: video-progress 20s linear infinite;
}

/* ═══════════════════════════════════════════════════
   FLOAT ANIMATION
   ═══════════════════════════════════════════════════ */
@keyframes float {
  0%   { transform: translateY(0px); }
  50%  { transform: translateY(-6px); }
  100% { transform: translateY(0px); }
}
.animate-float {
  animation: float 4s ease-in-out infinite;
}

/* ═══════════════════════════════════════════════════
   HOMEPAGE LAYOUT
   ═══════════════════════════════════════════════════ */
.homepage-shell {
  position: relative;
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.homepage-main {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80px 24px 0 24px;
}

.cards-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 28px;
  flex-wrap: nowrap;
}

/* Retro corner brackets on cards section */
.cards-frame {
  position: relative;
  padding: 32px;
}
.cards-frame::before,
.cards-frame::after {
  content: '';
  position: absolute;
  width: 24px;
  height: 24px;
  border-color: rgba(163, 224, 72, 0.12);
  border-style: solid;
  pointer-events: none;
}
.cards-frame::before {
  top: 0;
  left: 0;
  border-width: 1px 0 0 1px;
}
.cards-frame::after {
  bottom: 0;
  right: 0;
  border-width: 0 1px 1px 0;
}

/* Side label */
.side-label {
  position: absolute;
  left: 20px;
  top: 50%;
  transform: translateY(-50%) rotate(-90deg);
  transform-origin: center center;
  white-space: nowrap;
  font-size: 9px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.18);
  font-family: var(--font-space), sans-serif;
}

/* ═══════════════════════════════════════════════════
   SCROLLBAR HIDE
   ═══════════════════════════════════════════════════ */
.no-scrollbar::-webkit-scrollbar { display: none; }
.no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

/* ═══════════════════════════════════════════════════
   GLASS PANEL / BUTTON (legacy compat)
   ═══════════════════════════════════════════════════ */
.glass-panel {
  background: rgba(14, 14, 18, 0.85);
  border: 1px solid var(--border-subtle);
  backdrop-filter: blur(16px);
  border-radius: 12px;
  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
}

.glass-button {
  background: linear-gradient(180deg, #5a8c3a 0%, #4a7c2a 100%);
  border: 1px solid rgba(163, 224, 72, 0.3);
  box-shadow: 0 4px 16px rgba(90, 140, 58, 0.2), 0 1px 0 rgba(255,255,255,0.1) inset;
  color: #ffffff;
  transition: all 0.25s ease;
  border-radius: 10px;
  font-weight: 600;
  text-shadow: 0 1px 2px rgba(0,0,0,0.3);
}
.glass-button:hover {
  background: linear-gradient(180deg, #6b9e4a 0%, #5a8e3a 100%);
  box-shadow: 0 8px 24px rgba(90, 140, 58, 0.3), 0 1px 0 rgba(255,255,255,0.15) inset;
  transform: translateY(-1px);
}

/* MC Card (legacy) */
.mc-card {
  background: var(--bg-surface);
  border: 1px solid var(--border-subtle);
  border-radius: 12px;
  overflow: hidden;
}
.mc-card:hover {
  border-color: rgba(163, 224, 72, 0.15);
}

/* ═══════════════════════════════════════════════════
   RESPONSIVE
   ═══════════════════════════════════════════════════ */
@media (max-width: 960px) {
  .cards-row {
    flex-direction: column;
    gap: 20px;
  }
  .game-card {
    width: 240px;
    min-width: 240px;
  }
  .side-label {
    display: none;
  }
  .homepage-main {
    padding-top: 70px;
    overflow-y: auto;
  }
  .homepage-shell {
    height: auto;
    min-height: 100vh;
  }
}
